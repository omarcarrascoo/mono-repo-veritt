{
	"info": {
		"name": "Veritt Backend - Sprint 1",
		"description": "Flujo de pruebas para el Sprint 1. Incluye scripts para guardar el JWT Token y el Business ID automáticamente.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register user",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"owner@veritt.app\",\n  \"password\": \"password123\",\n  \"fullName\": \"Veritt Owner\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "register"]
				}
			}
		},
		{
			"name": "2. Login user",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if(jsonData.accessToken) {",
							"    pm.collectionVariables.set(\"token\", jsonData.accessToken);",
							"    console.log(\"Token guardado automáticamente\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"owner@veritt.app\",\n  \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "login"]
				}
			}
		},
		{
			"name": "3. GET /auth/me",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/auth/me",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "me"]
				}
			}
		},
		{
			"name": "4. Create business",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if(jsonData.id) {",
							"    pm.collectionVariables.set(\"businessId\", jsonData.id);",
							"    console.log(\"Business ID guardado automáticamente: \" + jsonData.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"La Taquería de Veritt\",\n  \"slug\": \"taqueria-veritt\",\n  \"businessType\": \"RESTAURANT\",\n  \"timezone\": \"America/Mexico_City\",\n  \"operationalDayCutoffHour\": 4\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/businesses",
					"host": ["{{baseUrl}}"],
					"path": ["businesses"]
				}
			}
		},
		{
			"name": "5. GET /businesses (Find Mine)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/businesses",
					"host": ["{{baseUrl}}"],
					"path": ["businesses"]
				}
			}
		},
		{
			"name": "6. GET Onboarding",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/businesses/{{businessId}}/onboarding",
					"host": ["{{baseUrl}}"],
					"path": ["businesses", "{{businessId}}", "onboarding"]
				}
			}
		},
		{
			"name": "7. PATCH Onboarding",
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"currentStep\": \"staff\",\n  \"completionPercentage\": 15,\n  \"generalInfoCompleted\": true\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/businesses/{{businessId}}/onboarding",
					"host": ["{{baseUrl}}"],
					"path": ["businesses", "{{businessId}}", "onboarding"]
				}
			}
		},
		{
			"name": "8. POST Staff Profile",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"fullName\": \"Juan Pérez\",\n  \"operationalRole\": \"Mesero Principal\",\n  \"shift\": \"Matutino\",\n  \"assignedAreasJson\": {\n    \"area\": \"Terraza\"\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/businesses/{{businessId}}/staff",
					"host": ["{{baseUrl}}"],
					"path": ["businesses", "{{businessId}}", "staff"]
				}
			}
		},
		{
			"name": "9. GET Staff Profiles",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/businesses/{{businessId}}/staff",
					"host": ["{{baseUrl}}"],
					"path": ["businesses", "{{businessId}}", "staff"]
				}
			}
		},
		{
			"name": "10. POST Add Member",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"admin@veritt.app\",\n  \"role\": \"ADMIN\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/businesses/{{businessId}}/members",
					"host": ["{{baseUrl}}"],
					"path": ["businesses", "{{businessId}}", "members"]
				},
				"description": "NOTA: El usuario con este correo (admin@veritt.app) YA DEBE EXISTIR en la tabla Users (haberse registrado antes) para poder agregarlo al negocio."
			}
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "businessId",
			"value": "",
			"type": "string"
		}
	]
}